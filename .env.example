APP_ENV=development
APP_LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COGNEE_API_KEY=
COGNEE_BASE_URL=

DEFAULT_MODEL=gpt-5
DEFAULT_EMBEDDING_MODEL=text-embedding-3-large

ROUBAIX_DEFAULT_DATASET=default
ROUBAIX_MAX_EVIDENCE_ITEMS=12
ROUBAIX_MAX_RETRIES=2
ROUBAIX_ENABLE_TEMPORAL=true

# Cache settings (HyperSpace-inspired content store)
ROUBAIX_CACHE_MAX_SIZE=4096
ROUBAIX_CACHE_DEFAULT_TTL_S=3600
ROUBAIX_CACHE_FRESHNESS_TTL_S=120

# Temporal settings
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=roubaix-router
